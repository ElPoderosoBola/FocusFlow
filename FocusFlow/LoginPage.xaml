<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FocusFlow.LoginPage">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{StaticResource AeroBackgroundTop}" Offset="0.0" />
            <GradientStop Color="{StaticResource AeroBackgroundBottom}" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <VerticalStackLayout VerticalOptions="Center" Spacing="30" Padding="40">

        <VerticalStackLayout Spacing="0" HorizontalOptions="Center" Margin="0,0,0,20">
            <Label Text="FOCUS" 
                   FontSize="48" 
                   FontAttributes="Bold" 
                   TextColor="{StaticResource AeroText}" 
                   HorizontalOptions="Center" 
                   CharacterSpacing="5"/>
            <Label Text="FLOW" 
                   FontSize="48" 
                   FontAttributes="Bold" 
                   TextColor="{StaticResource AeroGlow}" 
                   HorizontalOptions="Center" 
                   CharacterSpacing="5" 
                   Margin="0,-15,0,0"/>
        </VerticalStackLayout>

        <VerticalStackLayout Spacing="15">
            <Entry x:Name="UsernameEntry"
                   Placeholder="USUARIO" 
                   BackgroundColor="{StaticResource AeroPanel}" 
                   TextColor="{StaticResource AeroText}" 
                   PlaceholderColor="{StaticResource AeroSubText}"
                   HeightRequest="50"
                   Keyboard="Text" />

            <Entry x:Name="PasswordEntry"
                   Placeholder="CONTRASEÑA" 
                   BackgroundColor="{StaticResource AeroPanel}" 
                   TextColor="{StaticResource AeroText}" 
                   PlaceholderColor="{StaticResource AeroSubText}"
                   HeightRequest="50"
                   IsPassword="True" />
        </VerticalStackLayout>

        <VerticalStackLayout Spacing="15">
            <Button Text="ENTRAR" 
                    Clicked="OnLoginClicked"
                    BackgroundColor="{StaticResource AeroSkyDeep}" 
                    TextColor="White" 
                    FontAttributes="Bold"
                    HeightRequest="60"
                    CornerRadius="0" />

            <Button Text="CREAR CUENTA" 
                    Clicked="OnRegisterClicked"
                    BackgroundColor="{StaticResource AeroPanelSoft}" 
                    TextColor="{StaticResource AeroText}" 
                    FontAttributes="Bold"
                    HeightRequest="60"
                    CornerRadius="0" />
        </VerticalStackLayout>

    </VerticalStackLayout>
</ContentPage>