<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FocusFlow.LoginPage"
             Shell.NavBarIsVisible="False">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{StaticResource AeroBackgroundTop}" Offset="0.0" />
            <GradientStop Color="{StaticResource AeroBackgroundBottom}" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <VerticalStackLayout VerticalOptions="Center" Spacing="30" Padding="30">

        <Label Text="✨ FOCUSFLOW" 
               FontSize="36" 
               FontAttributes="Bold" 
               TextColor="{StaticResource AeroGlow}" 
               HorizontalOptions="Center" 
               CharacterSpacing="4"/>

        <Label Text="Gamifica tu productividad" 
               TextColor="{StaticResource AeroPanelLight}" 
               HorizontalOptions="Center" 
               FontSize="16" 
               Margin="0,-20,0,0"/>

        <Border Style="{StaticResource AeroGlassCard}" Padding="20">
            <VerticalStackLayout Spacing="20">

                <Border Style="{StaticResource AeroCardSoft}" Padding="10,0">
                    <Entry x:Name="UsernameEntry" 
                           Placeholder="👤 Nombre de héroe" 
                           TextColor="White" 
                           PlaceholderColor="{StaticResource AeroSubText}"
                           FontSize="16"/>
                </Border>

                <Border Style="{StaticResource AeroCardSoft}" Padding="10,0">
                    <Entry x:Name="PasswordEntry" 
                           Placeholder="🔑 Contraseña secreta" 
                           IsPassword="True" 
                           TextColor="White" 
                           PlaceholderColor="{StaticResource AeroSubText}"
                           FontSize="16"/>
                </Border>

                <Button Text="ENTRAR AL JUEGO" 
                        Clicked="OnLoginClicked" 
                        Style="{StaticResource AeroActionButton}" 
                        Margin="0,10,0,0"/>

                <Button Text="CREAR NUEVA CUENTA" 
                        Clicked="OnRegisterClicked" 
                        Style="{StaticResource AeroGhostButton}" />

            </VerticalStackLayout>
        </Border>
    </VerticalStackLayout>
</ContentPage>