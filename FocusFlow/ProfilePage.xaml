<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:FocusFlow.ViewModels"
             xmlns:models="clr-namespace:FocusFlow.Models"
             x:Class="FocusFlow.ProfilePage"
             x:DataType="viewmodel:ProfileViewModel">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{StaticResource AeroBackgroundTop}" Offset="0.0" />
            <GradientStop Color="{StaticResource AeroBackgroundBottom}" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="0,0,0,30">

            <Border Style="{StaticResource AeroCard}" Margin="20,20,20,0" Padding="30">
                <VerticalStackLayout Spacing="15" HorizontalOptions="Center">

                    <Label Text="PERFIL DE HÉROE" 
                           FontSize="12" 
                           TextColor="{StaticResource AeroGlow}" 
                           HorizontalOptions="Center" 
                           CharacterSpacing="2" 
                           FontAttributes="Bold"/>

                    <Label Text="{Binding CurrentUserProfile.Level, StringFormat='NIVEL {0}'}"
                           FontSize="48"
                           FontAttributes="Bold"
                           TextColor="{StaticResource AeroText}"
                           HorizontalOptions="Center" />

                    <HorizontalStackLayout Spacing="25" HorizontalOptions="Center">
                        <Label Text="{Binding CurrentUserProfile.Health, StringFormat='❤️ {0}'}"
                               TextColor="#FF5C5C"
                               FontSize="20"
                               FontAttributes="Bold"/>
                        <Label Text="/" TextColor="{StaticResource AeroSubText}" FontSize="20"/>
                        <Label Text="{Binding CurrentUserProfile.MaxHealth}"
                               TextColor="{StaticResource AeroSubText}"
                               FontSize="20"
                               FontAttributes="Bold"/>
                    </HorizontalStackLayout>

                    <Label Text="{Binding CurrentUserProfile.Coins, StringFormat='💰 {0} MONEDAS'}"
                           TextColor="#FFB900"
                           FontSize="22"
                           FontAttributes="Bold"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="20" Padding="20,0">

                <Button Text="CERRAR SESIÓN"
                        Command="{Binding LogoutCommand}"
                        BackgroundColor="{StaticResource AeroRed}"
                        TextColor="White"
                        FontAttributes="Bold"
                        HeightRequest="50"
                        CornerRadius="0" />

                <Border Style="{StaticResource AeroCard}" BackgroundColor="#233545" StrokeThickness="0" Padding="15">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="CUPO DE RECOMPENSAS CUSTOM" TextColor="{StaticResource Gray300}" FontSize="12" FontAttributes="Bold" />
                        <Label Text="{Binding CurrentCustomRewards, StringFormat='Usadas: {0}'}" TextColor="White" FontSize="16" />
                        <Label Text="{Binding MaxCustomRewards, StringFormat='Máximo disponible: {0}'}" TextColor="{StaticResource AeroSky}" FontSize="16" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>

                <Label Text="MIS LOGROS" 
                       Style="{StaticResource AeroSectionTitle}" />

                <CollectionView ItemsSource="{Binding Achievements}">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="2" VerticalItemSpacing="15" HorizontalItemSpacing="15" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:AchievementItem">
                            <Border Style="{StaticResource AeroCardSoft}" Padding="15" HeightRequest="140">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BackgroundColor" Value="{StaticResource AeroPanelSoft}" />
                                        <Style.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsUnlocked}" Value="True">
                                                <Setter Property="BackgroundColor" Value="{StaticResource AeroGold}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <VerticalStackLayout VerticalOptions="Center" Spacing="5">
                                    <Label Text="{Binding Title}" 
                                           FontSize="16" 
                                           FontAttributes="Bold">
                                        <Label.Style>
                                            <Style TargetType="Label">
                                                <Setter Property="TextColor" Value="{StaticResource AeroSubText}" />
                                                <Style.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding IsUnlocked}" Value="True">
                                                        <Setter Property="TextColor" Value="#2C2C2C" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Label.Style>
                                    </Label>

                                    <Label Text="{Binding Description}" 
                                           FontSize="11" 
                                           LineBreakMode="WordWrap">
                                        <Label.Style>
                                            <Style TargetType="Label">
                                                <Setter Property="TextColor" Value="{StaticResource AeroSubText}" />
                                                <Style.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding IsUnlocked}" Value="True">
                                                        <Setter Property="TextColor" Value="#2C2C2C" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Label.Style>
                                    </Label>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>