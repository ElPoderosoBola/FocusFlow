<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:FocusFlow.ViewModels"
             xmlns:models="clr-namespace:FocusFlow.Models"
             x:Class="FocusFlow.ProfilePage"
             x:DataType="viewmodel:ProfileViewModel"
             BackgroundColor="Black">

    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="0,0,0,30">

            <Border BackgroundColor="#1D1D1D" 
                    StrokeThickness="0" 
                    Padding="30"
                    Margin="0,0,0,10">
                <VerticalStackLayout Spacing="15" HorizontalOptions="Center">

                    <Label Text="PERFIL DE HÉROE" 
                           FontSize="12" 
                           TextColor="#00A4EF" 
                           HorizontalOptions="Center" 
                           CharacterSpacing="2" 
                           FontAttributes="Bold"/>

                    <Label Text="{Binding CurrentUserProfile.Level, StringFormat='NIVEL {0}'}"
                           FontSize="48"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center" />

                    <HorizontalStackLayout Spacing="25" HorizontalOptions="Center">
                        <Label Text="{Binding CurrentUserProfile.Health, StringFormat='❤️ {0}'}"
                               TextColor="#E81123"
                               FontSize="20"
                               FontAttributes="Bold"/>
                        <Label Text="/" TextColor="Gray" FontSize="20"/>
                        <Label Text="{Binding CurrentUserProfile.MaxHealth}"
                               TextColor="Gray"
                               FontSize="20"
                               FontAttributes="Bold"/>
                    </HorizontalStackLayout>

                    <Label Text="{Binding CurrentUserProfile.Coins, StringFormat='💰 {0} MONEDAS'}"
                           TextColor="#FFB900"
                           FontSize="22"
                           FontAttributes="Bold"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="20" Padding="20,0">

                <Label Text="MIS LOGROS" 
                       FontSize="28" 
                       FontAttributes="Bold" 
                       TextColor="White" />

                <CollectionView ItemsSource="{Binding Achievements}">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="2" VerticalItemSpacing="15" HorizontalItemSpacing="15" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:AchievementItem">
                            <Border StrokeThickness="0" Padding="15" HeightRequest="140">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BackgroundColor" Value="#222222" />
                                        <Style.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsUnlocked}" Value="True">
                                                <Setter Property="BackgroundColor" Value="#FFB900" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <VerticalStackLayout VerticalOptions="Center" Spacing="5">
                                    <Label Text="{Binding Title}" 
                                           FontSize="16" 
                                           FontAttributes="Bold">
                                        <Label.Style>
                                            <Style TargetType="Label">
                                                <Setter Property="TextColor" Value="#555555" />
                                                <Style.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding IsUnlocked}" Value="True">
                                                        <Setter Property="TextColor" Value="Black" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Label.Style>
                                    </Label>

                                    <Label Text="{Binding Description}" 
                                           FontSize="11" 
                                           LineBreakMode="WordWrap">
                                        <Label.Style>
                                            <Style TargetType="Label">
                                                <Setter Property="TextColor" Value="#444444" />
                                                <Style.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding IsUnlocked}" Value="True">
                                                        <Setter Property="TextColor" Value="#222222" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Label.Style>
                                    </Label>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>