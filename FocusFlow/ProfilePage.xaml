<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:FocusFlow.ViewModels"
             xmlns:models="clr-namespace:FocusFlow.Models"
             x:Class="FocusFlow.ProfilePage"
             x:DataType="viewmodel:ProfileViewModel"
             Title="Mi Perfil">

	<ContentPage.Background>
		<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
			<GradientStop Color="{StaticResource AeroBackgroundTop}" Offset="0.0" />
			<GradientStop Color="{StaticResource AeroBackgroundBottom}" Offset="1.0" />
		</LinearGradientBrush>
	</ContentPage.Background>

	<ScrollView>
		<VerticalStackLayout Spacing="25" Padding="20,30,20,40">

			<Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
				<Label Text="👤 MI PERFIL" Style="{StaticResource AeroSectionTitle}" VerticalOptions="Center" />
				<Button Grid.Column="1" Text="🚪 SALIR" Command="{Binding LogoutCommand}" Style="{StaticResource AeroGhostButton}" />
			</Grid>

			<Border Style="{StaticResource AeroGlassCard}" Padding="20">
				<VerticalStackLayout Spacing="15">
					<Label Text="ESTADÍSTICAS GENERALES" TextColor="{StaticResource AeroSkyDeep}" FontAttributes="Bold" FontSize="14" CharacterSpacing="2" />

					<Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto" RowSpacing="15" ColumnSpacing="15">

						<VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="0">
							<Label Text="Nivel Actual" TextColor="{StaticResource AeroSubText}" FontSize="12" FontAttributes="Bold"/>
							<Label Text="{Binding CurrentUserProfile.Level}" TextColor="White" FontSize="32" FontAttributes="Bold" />
						</VerticalStackLayout>

						<VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="0">
							<Label Text="Experiencia" TextColor="{StaticResource AeroSubText}" FontSize="12" FontAttributes="Bold"/>
							<Label Text="{Binding CurrentUserProfile.CurrentXP, StringFormat='{0} XP'}" TextColor="{StaticResource AeroGold}" FontSize="24" FontAttributes="Bold" />
						</VerticalStackLayout>

						<VerticalStackLayout Grid.Row="1" Grid.ColumnSpan="2" Spacing="5" Margin="0,10,0,0">
							<Label Text="🎒 Espacio de Caprichos (Tienda):" TextColor="{StaticResource AeroSubText}" FontSize="14" FontAttributes="Bold" />
							<HorizontalStackLayout Spacing="5">
								<Label Text="{Binding CurrentCustomRewards}" TextColor="White" FontSize="20" FontAttributes="Bold" />
								<Label Text="/" TextColor="{StaticResource AeroSubText}" FontSize="20" />
								<Label Text="{Binding MaxCustomRewards}" TextColor="{StaticResource AeroSubText}" FontSize="20" />
								<Label Text="usados" TextColor="{StaticResource AeroSubText}" FontSize="14" VerticalOptions="Center" Margin="5,0,0,0"/>
							</HorizontalStackLayout>
						</VerticalStackLayout>

					</Grid>
				</VerticalStackLayout>
			</Border>

			<Label Text="🏆 TUS LOGROS" Style="{StaticResource AeroSectionTitle}" Margin="0,10,0,0" />

			<CollectionView ItemsSource="{Binding Achievements}">
				<CollectionView.ItemTemplate>
					<DataTemplate x:DataType="models:AchievementItem">
						<Border Margin="0,0,0,12">

							<Border.Style>
								<Style TargetType="Border" BasedOn="{StaticResource AeroCardSoft}">
									<Style.Triggers>
										<DataTrigger TargetType="Border" Binding="{Binding IsUnlocked}" Value="False">
											<Setter Property="Opacity" Value="0.4" />
											<Setter Property="BackgroundColor" Value="#1A2E40" />
										</DataTrigger>
									</Style.Triggers>
								</Style>
							</Border.Style>

							<Grid ColumnDefinitions="Auto, *" Padding="15" ColumnSpacing="15">
								<Label Grid.Column="0" Text="🏅" FontSize="34" VerticalOptions="Center" />

								<VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
									<Label Text="{Binding Title}" TextColor="{StaticResource AeroText}" FontSize="18" FontAttributes="Bold" />
									<Label Text="{Binding Description}" TextColor="{StaticResource AeroSubText}" FontSize="13" />
								</VerticalStackLayout>
							</Grid>

						</Border>
					</DataTemplate>
				</CollectionView.ItemTemplate>
			</CollectionView>

		</VerticalStackLayout>
	</ScrollView>
</ContentPage>