<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:FocusFlow.ViewModels"
             xmlns:models="clr-namespace:FocusFlow.Models"
             x:Class="FocusFlow.MainPage"
             x:DataType="viewmodel:MainViewModel">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{StaticResource AeroBackgroundTop}" Offset="0.0" />
            <GradientStop Color="{StaticResource AeroBackgroundBottom}" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid>
        <ScrollView>
            <VerticalStackLayout Spacing="20" Padding="0,0,0,40">

                <Border Style="{StaticResource AeroGlassCard}" Margin="15,20,15,0" Padding="20">
                    <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto" BackgroundColor="Transparent">
                        <Label Grid.Row="0" Grid.ColumnSpan="2" Text="✨ FOCUSFLOW" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource AeroGlow}" CharacterSpacing="3" HorizontalOptions="Center" Margin="0,0,0,15" />

                        <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="5">
                            <HorizontalStackLayout Spacing="5">
                                <Label Text="❤️ Salud:" TextColor="{StaticResource AeroPanelLight}" FontSize="15" FontAttributes="Bold"/>
                                <Label Text="{Binding CurrentUserProfile.Health}" TextColor="White" FontAttributes="Bold" FontSize="16"/>
                                <Label Text="/" TextColor="{StaticResource AeroSubText}" FontSize="15"/>
                                <Label Text="{Binding CurrentUserProfile.MaxHealth}" TextColor="{StaticResource AeroSubText}" FontSize="15"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="5">
                                <Label Text="🌟 Exp:" TextColor="{StaticResource AeroGold}" FontSize="15" FontAttributes="Bold"/>
                                <Label Text="{Binding CurrentUserProfile.CurrentXP, StringFormat='{0} XP'}" TextColor="White" FontAttributes="Bold" FontSize="15"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="1" Grid.Column="1" HorizontalOptions="End">
                            <HorizontalStackLayout Spacing="5" HorizontalOptions="End">
                                <Label Text="Nivel" TextColor="{StaticResource AeroSubText}" FontSize="14" VerticalOptions="End"/>
                                <Label Text="{Binding CurrentUserProfile.Level}" TextColor="White" FontSize="26" FontAttributes="Bold"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="5" HorizontalOptions="End">
                                <Label Text="💰" FontSize="14"/>
                                <Label Text="{Binding CurrentUserProfile.Coins}" TextColor="{StaticResource AeroGold}" FontSize="18" FontAttributes="Bold"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <VerticalStackLayout Spacing="10" Padding="15,0">
                    <Grid ColumnDefinitions="*, Auto">
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="🌿" FontSize="22" />
                            <Label Text="HÁBITOS" Style="{StaticResource AeroSectionTitle}" />
                        </HorizontalStackLayout>
                        <Button Grid.Column="1" Text="+" Command="{Binding AddNewHabitCommand}" Style="{StaticResource AeroActionButton}" WidthRequest="45" HeightRequest="45" CornerRadius="22" />
                    </Grid>

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Habits}" Spacing="10">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:HabitItem">
                                <Border Style="{StaticResource AeroCardSoft}">
                                    <Grid ColumnDefinitions="Auto, Auto, *, Auto, Auto" Padding="12" ColumnSpacing="8">
                                        <Border Grid.Column="0" WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 10" Stroke="Transparent">
                                            <Image Source="{Binding ImagePath}" Aspect="AspectFill" />
                                        </Border>
                                        <Label Grid.Column="1" Text="🔄" FontSize="18" VerticalOptions="Center" />

                                        <Label Grid.Column="2" Text="{Binding Title}" VerticalOptions="Center" TextColor="{StaticResource AeroText}" FontSize="15" FontAttributes="Bold" LineBreakMode="WordWrap" />

                                        <Button Grid.Column="3" Text="🗑️" BackgroundColor="Transparent" TextColor="{StaticResource AeroRed}" Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainViewModel}}, Path=DeleteHabitCommand}" CommandParameter="{Binding .}" />
                                        <Button Grid.Column="4" Text="OK" BackgroundColor="{StaticResource AeroLime}" TextColor="#162533" CornerRadius="10" Padding="10,0" Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainViewModel}}, Path=ExecuteHabitCommand}" CommandParameter="{Binding .}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="10" Padding="15,0">
                    <Grid ColumnDefinitions="*, Auto">
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="🗡️" FontSize="22" />
                            <Label Text="MISIONES" Style="{StaticResource AeroSectionTitle}" />
                        </HorizontalStackLayout>
                        <Button Grid.Column="1" Text="+" Command="{Binding AddNewTaskCommand}" Style="{StaticResource AeroActionButton}" WidthRequest="45" HeightRequest="45" CornerRadius="22" />
                    </Grid>

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Tasks}" Spacing="10">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:TaskItem">
                                <Border Style="{StaticResource AeroCardSoft}">
                                    <Grid ColumnDefinitions="Auto, *, Auto, Auto" Padding="12" ColumnSpacing="8">
                                        <Border Grid.Column="0" WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 10" Stroke="Transparent">
                                            <Image Source="{Binding ImagePath}" Aspect="AspectFill" />
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                            <Label Text="{Binding Title}" TextColor="{StaticResource AeroText}" FontSize="15" FontAttributes="Bold" LineBreakMode="WordWrap" />
                                            <Label Text="{Binding DueDateTime, StringFormat='⏰ {0:dd/MM HH:mm}'}" TextColor="{StaticResource AeroSkyNight}" FontSize="11" />
                                        </VerticalStackLayout>
                                        <Button Grid.Column="2" Text="🗑️" BackgroundColor="Transparent" TextColor="{StaticResource AeroRed}" Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainViewModel}}, Path=DeleteTaskCommand}" CommandParameter="{Binding .}" />
                                        <Button Grid.Column="3" Text="LISTO" BackgroundColor="{StaticResource AeroSkyDeep}" TextColor="White" CornerRadius="10" Padding="10,0" Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainViewModel}}, Path=CompleteTaskCommand}" CommandParameter="{Binding .}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="10" Padding="15,0">
                    <Grid ColumnDefinitions="*, Auto">
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="🧪" FontSize="22" />
                            <Label Text="TIENDA" Style="{StaticResource AeroSectionTitle}" />
                        </HorizontalStackLayout>
                        <Button Grid.Column="1" Text="+" Command="{Binding AddNewRewardCommand}" Style="{StaticResource AeroActionButton}" WidthRequest="45" HeightRequest="45" CornerRadius="22" />
                    </Grid>

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Rewards}" Spacing="10">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:RewardItem">
                                <Border Style="{StaticResource AeroCardSoft}">
                                    <Grid ColumnDefinitions="Auto, *, Auto, Auto" Padding="12" ColumnSpacing="8">
                                        <Border Grid.Column="0" WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 10" Stroke="Transparent">
                                            <Image Source="{Binding ImagePath}" Aspect="AspectFill" />
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                            <Label Text="{Binding Title}" TextColor="{StaticResource AeroText}" FontSize="15" FontAttributes="Bold" LineBreakMode="WordWrap" />
                                            <Label Text="{Binding Cost, StringFormat='💰 {0}'}" TextColor="{StaticResource AeroSkyNight}" FontSize="12" />
                                        </VerticalStackLayout>
                                        <Button Grid.Column="2" Text="🗑️" BackgroundColor="Transparent" TextColor="{StaticResource AeroRed}" Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainViewModel}}, Path=DeleteRewardCommand}" CommandParameter="{Binding .}" />
                                        <Button Grid.Column="3" Text="COMPRAR" BackgroundColor="{StaticResource AeroGold}" TextColor="#162533" CornerRadius="10" Padding="10,0" Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainViewModel}}, Path=BuyRewardCommand}" CommandParameter="{Binding .}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <Grid IsVisible="{Binding IsCreatingTask}" BackgroundColor="#D9000000" Padding="20">
            <Border Style="{StaticResource AeroGlassCard}" VerticalOptions="Center" Padding="20" BackgroundColor="#1E2A33">
                <VerticalStackLayout Spacing="12">
                    <Label Text="NUEVA MISIÓN" Style="{StaticResource AeroSectionTitle}" HorizontalOptions="Center" FontSize="18" />
                    <Border Style="{StaticResource AeroCardSoft}" Padding="10,0">
                        <Entry Placeholder="Ej: Estudiar C#" Text="{Binding NewTaskTitle}" TextColor="White" PlaceholderColor="{StaticResource AeroSubText}" FontSize="14" />
                    </Border>
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="🪙 Monedas:" TextColor="White" VerticalOptions="Center" FontAttributes="Bold" FontSize="14"/>
                        <Entry Keyboard="Numeric" Text="{Binding NewTaskRewardCoinsText}" TextColor="{StaticResource AeroGold}" WidthRequest="60" FontAttributes="Bold" FontSize="14"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="📅 Fecha:" TextColor="White" VerticalOptions="Center" FontAttributes="Bold" FontSize="14"/>
                        <DatePicker Date="{Binding NewTaskDate}" TextColor="White" BackgroundColor="Transparent" FontSize="14"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="⏰ Hora:" TextColor="White" VerticalOptions="Center" FontAttributes="Bold" FontSize="14"/>
                        <TimePicker Time="{Binding NewTaskTime}" TextColor="White" BackgroundColor="Transparent" FontSize="14"/>
                    </HorizontalStackLayout>
                    <Button Text="🖼️ Adjuntar Foto" Command="{Binding PickImageCommand}" Style="{StaticResource AeroGhostButton}" FontSize="14" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,5,0,0">
                        <Button Grid.Column="0" Text="CANCELAR" Command="{Binding CancelTaskCommand}" Style="{StaticResource AeroGhostButton}" FontSize="13" />
                        <Button Grid.Column="1" Text="GUARDAR" Command="{Binding SaveTaskCommand}" Style="{StaticResource AeroActionButton}" FontSize="13" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid IsVisible="{Binding IsCreatingHabit}" BackgroundColor="#D9000000" Padding="20">
            <Border Style="{StaticResource AeroGlassCard}" VerticalOptions="Center" Padding="20" BackgroundColor="#1E2A33">
                <VerticalStackLayout Spacing="12">
                    <Label Text="NUEVO HÁBITO" Style="{StaticResource AeroSectionTitle}" HorizontalOptions="Center" FontSize="18" />
                    <Border Style="{StaticResource AeroCardSoft}" Padding="10,0">
                        <Entry Placeholder="Ej: Beber agua" Text="{Binding NewHabitTitle}" TextColor="White" PlaceholderColor="{StaticResource AeroSubText}" FontSize="14"/>
                    </Border>
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="🪙 Monedas:" TextColor="White" VerticalOptions="Center" FontAttributes="Bold" FontSize="14"/>
                        <Entry Keyboard="Numeric" Text="{Binding NewHabitRewardCoinsText}" TextColor="{StaticResource AeroGold}" WidthRequest="60" FontAttributes="Bold" FontSize="14"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="⏰ Hora:" TextColor="White" VerticalOptions="Center" FontAttributes="Bold" FontSize="14"/>
                        <TimePicker Time="{Binding NewHabitTime}" TextColor="White" BackgroundColor="Transparent" FontSize="14"/>
                    </HorizontalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="¿Qué días toca?" Style="{StaticResource AeroSectionTitle}" FontSize="13" HorizontalOptions="Center" />
                        <HorizontalStackLayout BindableLayout.ItemsSource="{Binding WeekDays}" Spacing="5" HorizontalOptions="Center">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:DayBubble">
                                    <Border WidthRequest="36" HeightRequest="36" StrokeShape="RoundRectangle 18" Stroke="Transparent">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainViewModel}}, Path=ToggleDayCommand}" CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BackgroundColor" Value="{StaticResource AeroCardSoft}" />
                                                <Style.Triggers>
                                                    <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="BackgroundColor" Value="{StaticResource AeroLime}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Label Text="{Binding Name}" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold" FontSize="14">
                                            <Label.Style>
                                                <Style TargetType="Label">
                                                    <Setter Property="TextColor" Value="{StaticResource AeroSubText}" />
                                                    <Style.Triggers>
                                                        <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="TextColor" Value="#162533" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Label.Style>
                                        </Label>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <Button Text="🖼️ Adjuntar Foto" Command="{Binding PickImageCommand}" Style="{StaticResource AeroGhostButton}" FontSize="14" Margin="0,5,0,0"/>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,5,0,0">
                        <Button Grid.Column="0" Text="CANCELAR" Command="{Binding CancelHabitCommand}" Style="{StaticResource AeroGhostButton}" FontSize="13"/>
                        <Button Grid.Column="1" Text="GUARDAR" Command="{Binding SaveHabitCommand}" Style="{StaticResource AeroActionButton}" FontSize="13"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid IsVisible="{Binding IsCreatingReward}" BackgroundColor="#D9000000" Padding="20">
            <Border Style="{StaticResource AeroGlassCard}" VerticalOptions="Center" Padding="20" BackgroundColor="#1E2A33">
                <VerticalStackLayout Spacing="12">
                    <Label Text="NUEVO CAPRICHO" Style="{StaticResource AeroSectionTitle}" HorizontalOptions="Center" FontSize="18" />
                    <Border Style="{StaticResource AeroCardSoft}" Padding="10,0">
                        <Entry Placeholder="Ej: Un café" Text="{Binding NewRewardTitle}" TextColor="White" PlaceholderColor="{StaticResource AeroSubText}" FontSize="14"/>
                    </Border>
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="🪙 Coste:" TextColor="White" VerticalOptions="Center" FontAttributes="Bold" FontSize="14"/>
                        <Entry Keyboard="Numeric" Text="{Binding NewRewardCostText}" TextColor="{StaticResource AeroGold}" WidthRequest="60" FontAttributes="Bold" FontSize="14" />
                    </HorizontalStackLayout>
                    <Button Text="🖼️ Adjuntar Foto" Command="{Binding PickImageCommand}" Style="{StaticResource AeroGhostButton}" FontSize="14"/>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,5,0,0">
                        <Button Grid.Column="0" Text="CANCELAR" Command="{Binding CancelRewardCommand}" Style="{StaticResource AeroGhostButton}" FontSize="13"/>
                        <Button Grid.Column="1" Text="GUARDAR" Command="{Binding SaveRewardCommand}" Style="{StaticResource AeroActionButton}" FontSize="13"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid IsVisible="{Binding IsAlertVisible}" BackgroundColor="#D9000000" Padding="25">
            <Border Style="{StaticResource AeroGlassCard}" VerticalOptions="Center" Padding="25" BackgroundColor="#1A2E40" Stroke="{StaticResource AeroSkyDeep}" StrokeThickness="2">
                <VerticalStackLayout Spacing="15">
                    <Label Text="{Binding AlertTitle}" Style="{StaticResource AeroSectionTitle}" HorizontalOptions="Center" FontSize="20" TextColor="{StaticResource AeroGlow}" />
                    <Label Text="{Binding AlertMessage}" TextColor="White" FontSize="15" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                    <Button Text="ENTENDIDO" Command="{Binding CloseAlertCommand}" CommandParameter="No" Style="{StaticResource AeroActionButton}" FontSize="14" Margin="0,10,0,0">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsConfirmMode}" Value="True">
                                <Setter Property="IsVisible" Value="False"/>
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10" IsVisible="{Binding IsConfirmMode}" Margin="0,10,0,0">
                        <Button Grid.Column="0" Text="NO" Command="{Binding CloseAlertCommand}" CommandParameter="No" Style="{StaticResource AeroGhostButton}" FontSize="14" />
                        <Button Grid.Column="1" Text="SÍ" Command="{Binding CloseAlertCommand}" CommandParameter="Yes" Style="{StaticResource AeroActionButton}" FontSize="14" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>