<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:FocusFlow.ViewModels"
             xmlns:models="clr-namespace:FocusFlow.Models"
             x:Class="FocusFlow.MainPage"
             x:DataType="viewmodel:MainViewModel"
             BackgroundColor="Black">

    <ScrollView>
        <VerticalStackLayout Spacing="30" Padding="0,0,0,30">

            <Grid ColumnDefinitions="*, Auto"
                  RowDefinitions="Auto, Auto, Auto"
                  Padding="20,40,20,20"
                  BackgroundColor="#1D1D1D">

                <Label Grid.Row="0" Grid.Column="0"
                       Text="FOCUSFLOW"
                       FontSize="12"
                       FontAttributes="Bold"
                       TextColor="#00A4EF"
                       CharacterSpacing="2" />

                <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="5" Margin="0,15,0,0">
                    <HorizontalStackLayout Spacing="5">
                        <Label Text="❤️ Salud:" TextColor="Gray" FontSize="14" VerticalOptions="Center"/>
                        <Label Text="{Binding CurrentUserProfile.Health}" TextColor="White" FontAttributes="Bold" FontSize="16"/>
                        <Label Text="/" TextColor="Gray" FontSize="14" VerticalOptions="Center"/>
                        <Label Text="{Binding CurrentUserProfile.MaxHealth}" TextColor="Gray" FontSize="14" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    <ProgressBar Progress="1.0" 
                                 ProgressColor="#E81123" 
                                 BackgroundColor="#333333" 
                                 HeightRequest="8"
                                 WidthRequest="200"
                                 HorizontalOptions="Start"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Row="1" Grid.Column="1" HorizontalOptions="End" VerticalOptions="End">
                    <HorizontalStackLayout Spacing="10" HorizontalOptions="End">
                        <Label Text="Nivel:" TextColor="Gray" FontSize="16" VerticalOptions="End"/>
                        <Label Text="{Binding CurrentUserProfile.Level}" TextColor="White" FontSize="28" FontAttributes="Bold" VerticalOptions="End"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="5" HorizontalOptions="End">
                        <Label Text="💰" FontSize="14" VerticalOptions="Center"/>
                        <Label Text="{Binding CurrentUserProfile.Coins}" TextColor="#FFB900" FontSize="18" FontAttributes="Bold"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Row="2" Grid.ColumnSpan="2" Margin="0,20,0,0">
                    <Label Text="EXPERIENCIA" HorizontalOptions="End" FontSize="10" TextColor="Gray" Margin="0,0,0,5"/>
                    <ProgressBar Progress="0.4" 
                                 ProgressColor="#00A4EF" 
                                 BackgroundColor="#333333" 
                                 HeightRequest="4"/>
                </VerticalStackLayout>
            </Grid>

            <Border BackgroundColor="#1D1D1D" StrokeThickness="0" Margin="20,0,20,0">
                <VerticalStackLayout Padding="30" Spacing="20">
                    <Label Text="TEMPORIZADOR DE ENFOQUE" 
                           FontSize="12" 
                           TextColor="Gray" 
                           HorizontalOptions="Center" 
                           CharacterSpacing="2"/>

                    <Label Text="{Binding TimerDisplay}"
                           FontSize="85"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center" />

                    <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">
                        <Button Text="INICIAR ENFOQUE"
                                Command="{Binding StartTimerCommand}"
                                BackgroundColor="#00A4EF"
                                TextColor="White"
                                CornerRadius="0"
                                FontAttributes="Bold"
                                Padding="20,10"/>

                        <Button Text="RENDIRSE"
                                Command="{Binding StopTimerCommand}"
                                BackgroundColor="#E81123"
                                TextColor="White"
                                CornerRadius="0"
                                FontAttributes="Bold"
                                Padding="20,10"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="40" Padding="20,0">

                <VerticalStackLayout Spacing="15">
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <Label Text="HÁBITOS" FontSize="28" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="+" Command="{Binding AddNewHabitCommand}"
                                BackgroundColor="#333333" TextColor="White" WidthRequest="45" HeightRequest="45"
                                CornerRadius="0" FontSize="20" FontAttributes="Bold" />
                    </Grid>

                    <CollectionView ItemsSource="{Binding Habits}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:HabitItem">
                                <Grid ColumnDefinitions="*, Auto, Auto" BackgroundColor="#2D2D2D" Padding="15" Margin="0,0,0,10">
                                    <Label Text="{Binding Title}" VerticalOptions="Center" TextColor="White" FontSize="16" />

                                    <Button Grid.Column="1" Text="🗑️" 
                                            BackgroundColor="Transparent" TextColor="#E81123" FontSize="18"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainViewModel}}, Path=DeleteHabitCommand}"
                                            CommandParameter="{Binding .}" Margin="0,0,10,0" />

                                    <Button Grid.Column="2" Text="EJECUTAR" BackgroundColor="#107C10" TextColor="White"
                                            CornerRadius="0" FontAttributes="Bold"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainViewModel}}, Path=ExecuteHabitCommand}"
                                            CommandParameter="{Binding .}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="15">
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <Label Text="DIARIAS" FontSize="28" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="+" Command="{Binding AddNewDailyCommand}"
                                BackgroundColor="#333333" TextColor="White" WidthRequest="45" HeightRequest="45"
                                CornerRadius="0" FontSize="20" FontAttributes="Bold" />
                    </Grid>

                    <CollectionView ItemsSource="{Binding Dailies}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:DailyItem">
                                <Grid ColumnDefinitions="*, Auto, Auto" BackgroundColor="#2D2D2D" Padding="15" Margin="0,0,0,10">
                                    <Label Text="{Binding Title}" VerticalOptions="Center" TextColor="White" FontSize="16" />

                                    <Button Grid.Column="1" Text="🗑️" 
                                            BackgroundColor="Transparent" TextColor="#E81123" FontSize="18"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainViewModel}}, Path=DeleteDailyCommand}"
                                            CommandParameter="{Binding .}" Margin="0,0,10,0" />

                                    <Button Grid.Column="2" Text="COMPLETAR" BackgroundColor="#0078D7" TextColor="White"
                                            CornerRadius="0" FontAttributes="Bold"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainViewModel}}, Path=CompleteDailyCommand}"
                                            CommandParameter="{Binding .}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="15">
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <Label Text="TAREAS" FontSize="28" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="+" Command="{Binding AddNewTaskCommand}"
                                BackgroundColor="#333333" TextColor="White" WidthRequest="45" HeightRequest="45"
                                CornerRadius="0" FontSize="20" FontAttributes="Bold" />
                    </Grid>

                    <CollectionView ItemsSource="{Binding Tasks}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:TaskItem">
                                <Grid ColumnDefinitions="*, Auto, Auto" BackgroundColor="#2D2D2D" Padding="15" Margin="0,0,0,10">
                                    <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                        <Label Text="{Binding Title}" TextColor="White" FontSize="16" FontAttributes="Bold" />
                                        <Label Text="{Binding EstimatedMinutes, StringFormat='{0} min'}" TextColor="Gray" FontSize="12" />
                                    </VerticalStackLayout>

                                    <Button Grid.Column="1" Text="🗑️" 
                                            BackgroundColor="Transparent" TextColor="#E81123" FontSize="18"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainViewModel}}, Path=DeleteTaskCommand}"
                                            CommandParameter="{Binding .}" Margin="0,0,10,0" />

                                    <Button Grid.Column="2" Text="TERMINAR" BackgroundColor="#B4009E" TextColor="White"
                                            CornerRadius="0" FontAttributes="Bold"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainViewModel}}, Path=CompleteTaskCommand}"
                                            CommandParameter="{Binding .}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="15" Margin="0,20,0,0">
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <Label Text="TIENDA DE RECOMPENSAS" FontSize="24" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="+" Command="{Binding AddNewRewardCommand}"
                                BackgroundColor="#333333" TextColor="White" WidthRequest="45" HeightRequest="45"
                                CornerRadius="0" FontSize="20" FontAttributes="Bold" />
                    </Grid>

                    <CollectionView ItemsSource="{Binding Rewards}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:RewardItem">
                                <Grid ColumnDefinitions="*, Auto" BackgroundColor="#2D2D2D" Padding="15" Margin="0,0,0,10">
                                    <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                        <Label Text="{Binding Title}" TextColor="White" FontSize="16" FontAttributes="Bold" />
                                        <Label Text="{Binding Cost, StringFormat='{0} monedas'}" TextColor="#FFB900" FontSize="14" />
                                    </VerticalStackLayout>
                                    <Button Grid.Column="1" Text="COMPRAR" BackgroundColor="#D83B01" TextColor="White"
                                            CornerRadius="0" FontAttributes="Bold"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainViewModel}}, Path=BuyRewardCommand}"
                                            CommandParameter="{Binding .}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>