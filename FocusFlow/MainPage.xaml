<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:FocusFlow.ViewModels"
             xmlns:models="clr-namespace:FocusFlow.Models"
             x:Class="FocusFlow.MainPage"
             x:DataType="viewmodel:MainViewModel">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{StaticResource AeroBackgroundTop}" Offset="0.0" />
            <GradientStop Color="{StaticResource AeroBackgroundBottom}" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Spacing="30" Padding="0,0,0,30">

            <Border Style="{StaticResource AeroCard}" Margin="20,20,20,0" Padding="0">
                <Grid ColumnDefinitions="*, Auto"
                  RowDefinitions="Auto, Auto, Auto"
                  Padding="20,40,20,20"
                  BackgroundColor="Transparent">

                <Label Grid.Row="0" Grid.Column="0"
                       Text="FOCUSFLOW"
                       FontSize="12"
                       FontAttributes="Bold"
                       TextColor="{StaticResource AeroGlow}"
                       CharacterSpacing="2" />

                <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="5" Margin="0,15,0,0">
                    <HorizontalStackLayout Spacing="5">
                        <Label Text="❤️ Salud:" TextColor="{StaticResource AeroSubText}" FontSize="14" VerticalOptions="Center"/>
                        <Label Text="{Binding CurrentUserProfile.Health}" TextColor="{StaticResource AeroText}" FontAttributes="Bold" FontSize="16"/>
                        <Label Text="/" TextColor="{StaticResource AeroSubText}" FontSize="14" VerticalOptions="Center"/>
                        <Label Text="{Binding CurrentUserProfile.MaxHealth}" TextColor="{StaticResource AeroSubText}" FontSize="14" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    <ProgressBar Progress="1.0" 
                                 ProgressColor="#E81123" 
                                 BackgroundColor="#1B2B36" 
                                 HeightRequest="8"
                                 WidthRequest="200"
                                 HorizontalOptions="Start"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Row="1" Grid.Column="1" HorizontalOptions="End" VerticalOptions="End">
                    <HorizontalStackLayout Spacing="10" HorizontalOptions="End">
                        <Label Text="Nivel:" TextColor="{StaticResource AeroSubText}" FontSize="16" VerticalOptions="End"/>
                        <Label Text="{Binding CurrentUserProfile.Level}" TextColor="{StaticResource AeroText}" FontSize="28" FontAttributes="Bold" VerticalOptions="End"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="5" HorizontalOptions="End">
                        <Label Text="💰" FontSize="14" VerticalOptions="Center"/>
                        <Label Text="{Binding CurrentUserProfile.Coins}" TextColor="{StaticResource AeroGold}" FontSize="18" FontAttributes="Bold"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Row="2" Grid.ColumnSpan="2" Margin="0,20,0,0">
                    <Label Text="EXPERIENCIA" HorizontalOptions="End" FontSize="10" TextColor="{StaticResource Gray300}" Margin="0,0,0,5"/>
                    <ProgressBar Progress="0.4" 
                                 ProgressColor="{StaticResource AeroSkyDeep}" 
                                 BackgroundColor="#1E2A33" 
                                 HeightRequest="4"/>
                </VerticalStackLayout>
            </Grid>
            </Border>

            <VerticalStackLayout Spacing="40" Padding="20,0">

                <VerticalStackLayout Spacing="15">
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <Label Text="HÁBITOS" Style="{StaticResource AeroSectionTitle}" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="+" Command="{Binding AddNewHabitCommand}" Style="{StaticResource AeroActionButton}"
                                WidthRequest="45" HeightRequest="45"
                                CornerRadius="0" FontSize="20" FontAttributes="Bold" />
                    </Grid>

                    <CollectionView ItemsSource="{Binding Habits}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:HabitItem">
                                <Border Style="{StaticResource AeroCardSoft}" Margin="0,0,0,10">
                                    <Grid ColumnDefinitions="*, Auto, Auto" Padding="15">
                                        <Label Text="{Binding Title}" VerticalOptions="Center" TextColor="{StaticResource AeroText}" FontSize="16" />

                                    <Button Grid.Column="1" Text="🗑️" 
                                            BackgroundColor="Transparent" TextColor="#E81123" FontSize="18"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainViewModel}}, Path=DeleteHabitCommand}"
                                            CommandParameter="{Binding .}" Margin="0,0,10,0" />

                                        <Button Grid.Column="2" Text="EJECUTAR" BackgroundColor="{StaticResource AeroLime}" TextColor="Black"
                                                CornerRadius="10" FontAttributes="Bold"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainViewModel}}, Path=ExecuteHabitCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="15">
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <Label Text="TAREAS" Style="{StaticResource AeroSectionTitle}" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="+" Command="{Binding AddNewTaskCommand}" Style="{StaticResource AeroActionButton}"
                                WidthRequest="45" HeightRequest="45"
                                CornerRadius="0" FontSize="20" FontAttributes="Bold" />
                    </Grid>

                    <CollectionView ItemsSource="{Binding Tasks}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:TaskItem">
                                <Border Style="{StaticResource AeroCardSoft}" Margin="0,0,0,10">
                                    <Grid ColumnDefinitions="*, Auto, Auto" Padding="15">
                                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                            <Label Text="{Binding Title}" TextColor="{StaticResource AeroText}" FontSize="16" FontAttributes="Bold" />
                                            <Label Text="{Binding EstimatedMinutes, StringFormat='{0} min'}" TextColor="{StaticResource AeroSubText}" FontSize="12" />
                                            <Label Text="{Binding DueDateTime, StringFormat='Límite: {0:dd/MM HH:mm}'}" TextColor="{StaticResource AeroSubText}" FontSize="12" />
                                            <Label Text="{Binding RewardCoins, StringFormat='Recompensa: {0} monedas'}" TextColor="{StaticResource AeroGold}" FontSize="12" />
                                        </VerticalStackLayout>

                                    <Button Grid.Column="1" Text="🗑️" 
                                            BackgroundColor="Transparent" TextColor="#E81123" FontSize="18"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainViewModel}}, Path=DeleteTaskCommand}"
                                            CommandParameter="{Binding .}" Margin="0,0,10,0" />

                                        <Button Grid.Column="2" Text="TERMINAR" BackgroundColor="{StaticResource AeroSkyDeep}" TextColor="White"
                                                CornerRadius="10" FontAttributes="Bold"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainViewModel}}, Path=CompleteTaskCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="15" Margin="0,20,0,0">
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <Label Text="TIENDA DE RECOMPENSAS" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource AeroText}" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="+" Command="{Binding AddNewRewardCommand}" Style="{StaticResource AeroActionButton}"
                                WidthRequest="45" HeightRequest="45"
                                CornerRadius="0" FontSize="20" FontAttributes="Bold" />
                    </Grid>

                    <CollectionView ItemsSource="{Binding Rewards}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:RewardItem">
                                <Border Style="{StaticResource AeroCardSoft}" Margin="0,0,0,10">
                                    <Grid ColumnDefinitions="*, Auto" Padding="15">
                                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                            <Label Text="{Binding Title}" TextColor="{StaticResource AeroText}" FontSize="16" FontAttributes="Bold" />
                                            <Label Text="{Binding Cost, StringFormat='{0} monedas'}" TextColor="{StaticResource AeroGold}" FontSize="14" />
                                        </VerticalStackLayout>
                                        <Button Grid.Column="1" Text="COMPRAR" BackgroundColor="{StaticResource AeroSkyDeep}" TextColor="White"
                                                CornerRadius="10" FontAttributes="Bold"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainViewModel}}, Path=BuyRewardCommand}"
                                                CommandParameter="{Binding .}" />
                                        <Button Grid.Column="1" Text="🗑️" BackgroundColor="Transparent" TextColor="#E81123" FontSize="18"
                                                VerticalOptions="Start"
                                                HorizontalOptions="End"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainViewModel}}, Path=DeleteRewardCommand}"
                                                CommandParameter="{Binding .}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>